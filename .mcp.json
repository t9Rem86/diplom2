{
  "mcpServers": {
    "finmodel": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "finmodel.mcp_server"]
    },
    "excel": {
      "type": "stdio",
      "command": "uvx",
      "args": ["excel-mcp-server", "stdio"],
      "env": {
        "EXCEL_FILES_PATH": "."
      }
    }
  }
}
